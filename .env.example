# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# URL del frontend (en producción, el dominio público con https). En dev: http://localhost:3000
FRONTEND_URL=https://danacorp.tudominio.cl

# Secreto para firmar los JWT. Generar uno fuerte y aleatorio (>=32 chars), p.ej.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Variables separadas (recomendado si el usuario/clave tienen caracteres especiales):
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=danacorp
# Alternativa: una sola URL (tiene prioridad sobre las PG* si está definida):
# DATABASE_URL=postgres://usuario:clave@host:5432/danacorp

# ── Archivos subidos ──────────────────────────────────────────────────────────
# Carpeta persistente fuera del árbol de deploy (incluir en el backup). Default: ./uploads
UPLOADS_DIR=/var/lib/danacorp/uploads

# ── Gemini (IA, opcional) ─────────────────────────────────────────────────────
# Solo en el backend; NUNCA se expone al navegador. Si no se usa la importación
# legacy con IA, dejar en blanco.
GEMINI_API_KEY=
